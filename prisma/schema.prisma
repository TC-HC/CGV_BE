// Prisma schema for the CGV CV block API.
// DATABASE_URL is loaded from prisma.config.ts and consumed by Prisma's pg adapter.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int       @id @default(autoincrement())
  name        String
  tagline     String?
  bio         String?
  email       String?
  github      String?
  profileType String    @default("dev")
  viewMode    String    @default("list")
  shareSlug   String    @unique @default(uuid())
  isPublic    Boolean   @default(true)
  sections    Section[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Section {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  category  String   @default("기타")
  order     Int      @default(0)
  blocks    Block[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, order])
}

model Block {
  id           Int      @id @default(autoincrement())
  sectionId    Int
  section      Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  type         String
  order        Int      @default(0)
  title        String
  period       String?
  role         String?
  summary      String?
  detail       String?
  result       String?
  date         String?
  certLink     String?
  certImageUrl String?
  stack        String?
  link         String?
  contentType  String?
  emoji        String?
  isPublic     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sectionId, order])
}
